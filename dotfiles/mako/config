# Dimensions et position (en haut à droite)
anchor=top-right
width=350
height=110
margin=15
padding=15

# Typographie (on réutilise ta police Cascadia)
font=JetBrainsMonoNF-Regular Font 10
markup=1

# Couleurs (Thème sombre avec bordure magenta/bordeaux)
background-color=#1a1b26
text-color=#bb9af7
border-color=#a200a2
border-size=2
border-radius=5

# Comportement
default-timeout=5000
max-visible=3

# Raccourcis de la souris
on-button-left=dismiss
on-button-right=dismiss-all
on-button-middle=invoke-default-action
